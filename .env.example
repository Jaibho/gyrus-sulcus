# Site URL (used by SEO metadata + JSON-LD schema)
NEXT_PUBLIC_SITE_URL=https://gyrussulcus.com

# Google Analytics 4 — get from https://analytics.google.com → Admin → Data Streams
# Looks like: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity — get from https://clarity.microsoft.com → Settings → Overview
# Looks like: abcd1234ef
NEXT_PUBLIC_CLARITY_ID=

# Tawk.to live chat — get from https://dashboard.tawk.to → Admin → Channels → Chat Widget
# Property ID (first UUID) and Widget ID (second, usually starts with "1")
NEXT_PUBLIC_TAWK_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=
